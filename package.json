{
  "name": "@fido/credential-schemas",
  "version": "0.1.0",
  "private": true,
  "description": "Dual-format (W3C VC 2.0 + SD-JWT VC) verifiable credential schema registry for the FIDO Alliance.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build:registry": "tsx scripts/build-registry.ts",
    "seal": "tsx scripts/seal-examples.ts",
    "validate": "tsx scripts/validate.ts",
    "typecheck": "pnpm -r --if-present typecheck && tsc -p tsconfig.scripts.json --noEmit",
    "lint": "prettier --check \"**/*.{ts,json,jsonld,md}\"",
    "format": "prettier --write \"**/*.{ts,json,jsonld,md}\"",
    "build:site": "pnpm --filter @fido/site build",
    "dev:site": "pnpm --filter @fido/site dev"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
