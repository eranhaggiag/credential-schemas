{
  "$comment": "Glide Identity — Phone Number Verification JSON-LD context. Targets W3C VCDM 2.0 (15 May 2025). Use with https://www.w3.org/ns/credentials/v2.",
  "@context": {
    "@protected": true,
    "PhoneVerificationCredential": "https://schemas.glideidentity.app/contexts/phone-verification.jsonld#PhoneVerificationCredential",
    "glide": "https://schemas.glideidentity.app/vocab#",
    "phone_number": {
      "@id": "glide:phone_number",
      "@type": "http://www.w3.org/2001/XMLSchema#string"
    },
    "verification_method": {
      "@id": "glide:verification_method",
      "@type": "http://www.w3.org/2001/XMLSchema#string"
    },
    "verified_at": {
      "@id": "glide:verified_at",
      "@type": "http://www.w3.org/2001/XMLSchema#dateTime"
    },
    "carrier_attested": {
      "@id": "glide:carrier_attested",
      "@type": "http://www.w3.org/2001/XMLSchema#boolean"
    }
  }
}
