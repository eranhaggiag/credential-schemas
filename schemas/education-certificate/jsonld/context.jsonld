{
  "$comment": "FIDO Alliance — Education Certificate JSON-LD context. Targets W3C VCDM 2.0 (15 May 2025). Use with https://www.w3.org/ns/credentials/v2.",
  "@context": {
    "@protected": true,
    "EducationCertificateCredential": "https://schemas.fido.example/contexts/education-certificate.jsonld#EducationCertificateCredential",
    "fido": "https://schemas.fido.example/vocab#",
    "institution": {
      "@id": "fido:institution",
      "@type": "http://www.w3.org/2001/XMLSchema#string"
    },
    "credential_name": {
      "@id": "fido:credential_name",
      "@type": "http://www.w3.org/2001/XMLSchema#string"
    },
    "field_of_study": {
      "@id": "fido:field_of_study",
      "@type": "http://www.w3.org/2001/XMLSchema#string"
    },
    "award_date": { "@id": "fido:award_date", "@type": "http://www.w3.org/2001/XMLSchema#date" },
    "grade": { "@id": "fido:grade", "@type": "http://www.w3.org/2001/XMLSchema#string" },
    "accreditation_body": {
      "@id": "fido:accreditation_body",
      "@type": "http://www.w3.org/2001/XMLSchema#string"
    }
  }
}
