{
  "$comment": "Glide Identity — Email Verification JSON-LD context. Targets W3C VCDM 2.0 (15 May 2025). Use with https://www.w3.org/ns/credentials/v2.",
  "@context": {
    "@protected": true,
    "EmailVerificationCredential": "https://schemas.glideidentity.app/contexts/email-verification.jsonld#EmailVerificationCredential",
    "glide": "https://schemas.glideidentity.app/vocab#",
    "email": { "@id": "glide:email", "@type": "http://www.w3.org/2001/XMLSchema#string" },
    "verification_method": {
      "@id": "glide:verification_method",
      "@type": "http://www.w3.org/2001/XMLSchema#string"
    },
    "verified_at": {
      "@id": "glide:verified_at",
      "@type": "http://www.w3.org/2001/XMLSchema#dateTime"
    }
  }
}
