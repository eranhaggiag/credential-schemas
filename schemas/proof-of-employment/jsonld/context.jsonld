{
  "$comment": "FIDO Alliance — Proof of Employment JSON-LD context. Targets W3C VCDM 2.0 (15 May 2025). Use with https://www.w3.org/ns/credentials/v2.",
  "@context": {
    "@protected": true,
    "ProofOfEmploymentCredential": "https://schemas.fido.example/contexts/proof-of-employment.jsonld#ProofOfEmploymentCredential",
    "fido": "https://schemas.fido.example/vocab#",
    "employer": { "@id": "fido:employer", "@type": "http://www.w3.org/2001/XMLSchema#string" },
    "status": {
      "@id": "fido:employment_relationship",
      "@type": "http://www.w3.org/2001/XMLSchema#string"
    },
    "employment_start": {
      "@id": "fido:employment_start",
      "@type": "http://www.w3.org/2001/XMLSchema#date"
    },
    "employment_end": {
      "@id": "fido:employment_end",
      "@type": "http://www.w3.org/2001/XMLSchema#date"
    }
  }
}
