{
  "$comment": "Glide Identity — Proof of Employment JSON-LD context. Targets W3C VCDM 2.0 (15 May 2025). Use with https://www.w3.org/ns/credentials/v2.",
  "@context": {
    "@protected": true,
    "ProofOfEmploymentCredential": "https://schemas.glideidentity.app/contexts/proof-of-employment.jsonld#ProofOfEmploymentCredential",
    "glide": "https://schemas.glideidentity.app/vocab#",
    "employer": { "@id": "glide:employer", "@type": "http://www.w3.org/2001/XMLSchema#string" },
    "status": {
      "@id": "glide:employment_relationship",
      "@type": "http://www.w3.org/2001/XMLSchema#string"
    },
    "employment_start": {
      "@id": "glide:employment_start",
      "@type": "http://www.w3.org/2001/XMLSchema#date"
    },
    "employment_end": {
      "@id": "glide:employment_end",
      "@type": "http://www.w3.org/2001/XMLSchema#date"
    }
  }
}
