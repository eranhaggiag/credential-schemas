---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Dual-format verifiable credential schemas (W3C VC 2.0 + SD-JWT VC) for the FIDO Alliance.' } = Astro.props;
const repoUrl = 'https://github.com/GlideIdentity/credential-schemas';
const base = import.meta.env.BASE_URL;
const here = Astro.url.pathname.replace(/\/$/, '');

const nav = [
  { href: base, label: 'Home', match: '' },
  { href: `${base}registry`.replace(/\/\//g, '/'), label: 'Schemas', match: 'registry' },
  { href: `${base}docs`.replace(/\/\//g, '/'), label: 'Developer docs', match: 'docs' },
];
const isActive = (m: string) => (m === '' ? here === base.replace(/\/$/, '') : here.includes(m));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · FIDO Schemas</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}logo.svg`.replace(/\/\//g, '/')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="sticky top-0 z-20 border-b border-white/10 bg-brand-900/70 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href={base} class="flex items-center gap-3">
          <img src={`${base}logo.svg`.replace(/\/\//g, '/')} alt="FIDO Schemas" class="h-7 w-7" />
          <span class="font-heading text-white">FIDO <span class="text-white/60">Schemas</span></span>
        </a>
        <nav class="flex items-center gap-1 text-sm">
          {
            nav.map((n) => (
              <a
                href={n.href}
                class:list={[
                  'rounded-lg px-3 py-1.5',
                  isActive(n.match) ? 'text-white bg-white/10' : 'text-white/70 hover:text-white',
                ]}
              >
                {n.label}
              </a>
            ))
          }
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-white/70 hover:text-white"
            aria-label="View source on GitHub"
          >
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
            <span>GitHub</span>
          </a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-white/10">
      <div class="mx-auto max-w-6xl px-6 py-8 text-sm text-white/50">
        <p>
          FIDO Schemas · Apache-2.0 · W3C VC 2.0 + SD-JWT VC (draft-16).
          Examples use fake data. ·
          <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="text-white/70 underline hover:text-white">GitHub</a>
        </p>
      </div>
    </footer>
  </body>
</html>
