---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---

<Base title="Not found">
  <div class="py-16 text-center">
    <div class="numeral text-6xl text-white">404</div>
    <p class="mt-4 text-white/70">That page isn't in the registry.</p>
    <a class="btn btn-primary mt-6" href={base}>Back home</a>
  </div>
</Base>
