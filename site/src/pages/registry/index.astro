---
import Base from '../../layouts/Base.astro';
import { getRegistry } from '../../lib/content';

const registry = getRegistry();
const base = import.meta.env.BASE_URL;
const href = (id: string) => `${base}registry/${id}`.replace(/\/\//g, '/');
---

<Base title="Schema registry">
  <h1 class="text-3xl">Schema registry</h1>
  <p class="mt-3 max-w-2xl text-white/70">
    {registry.credentials.length} credential types, generated from
    <code>schemas/registry.json</code>. Each is available as W3C VC 2.0 JSON-LD and SD-JWT VC.
  </p>

  <div class="mt-4 flex flex-wrap gap-2 text-xs text-white/50">
    <span class="chip">W3C VCDM {registry.specs.w3cVcDataModel.includes('2.0') ? '2.0' : ''}</span>
    <span class="chip">SD-JWT VC draft-16</span>
    <span class="chip">RFC 9901</span>
    <span class="chip">JSON Schema 2020-12</span>
  </div>

  <ul class="mt-8 grid gap-4 sm:grid-cols-2">
    {
      registry.credentials.map((c) => (
        <li>
          <a href={href(c.id)} class="card block h-full p-5 hover:border-white/25">
            <div class="flex items-start justify-between gap-3">
              <h2 class="text-lg">{c.name}</h2>
              <span class="numeral text-xs text-white/40">v{c.version}</span>
            </div>
            <p class="mt-2 text-sm text-white/70">{c.description}</p>
            <p class="mt-3 truncate font-grotesk text-xs accent">{c.vct}</p>
          </a>
        </li>
      ))
    }
  </ul>
</Base>
